{
    "name": "osoobe/laravel-settings",
    "description": "A description for laravel-settings.",
    "type": "package",
    "license": "MIT",
    "keywords": [
        "laravel"
    ],
    "authors": [
        {
            "name": "Oshane Bailey",
            "email": "b4.oshany@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "suggest": {
        "osoobe/laravel-utilities": "Required for getVersionHostnames() and appendVersionHostname() on AppMeta."
    },
    "autoload": {
        "psr-4": {
            "Osoobe\\Laravel\\Settings\\": "./src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Osoobe\\Laravel\\Settings\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Osoobe\\Laravel\\Settings\\LaravelSettingsServiceProvider"
            ]
        }
    },
    "require-dev": {
        "orchestra/testbench": "^6.0"
    }
}
